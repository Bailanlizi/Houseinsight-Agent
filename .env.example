# DashScope / OpenAI 兼容（Qwen）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-turbo
# answer 节点专用温度（建议 0～0.2，越低越稳定）
ANSWER_LLM_TEMPERATURE=0

# Agent
MAX_ITERATIONS=10
# 自动清洗阶段 observe 迭代上限（与 MAX_ITERATIONS 取 min 后再与请求 max_iterations 取 min）
MAX_CLEANING_ITERATIONS=4
# 分析阶段单轮 run 内同类工具成功次数上限（0=禁止再次成功执行）
MAX_SEARCH_TEXT_PER_RUN=1
MAX_GET_BASIC_STATS_PER_RUN=1
MAX_FILTER_ROWS_PER_RUN=3
# 单次 LLM HTTP 超时（秒）
LLM_TIMEOUT_SECONDS=60
# LangChain ChatOpenAI 在可重试错误上的最大重试次数（0=不重试，总请求次数=1+该值）
LLM_MAX_RETRIES=1
HI_MOCK_LLM=0
# 分析阶段规则 observe（1=先走确定性逻辑，仅不确定时调 observe LLM）
ANALYZE_RULE_OBSERVE_ENABLED=1

# 日志：1 时记录 LLM 请求/响应摘要（勿在生产长期开启）
LOG_LLM_IO=0

# 上传与数据规模（可选，代码内有默认值）
MAX_UPLOAD_BYTES=10485760
MAX_CSV_ROWS=200000
